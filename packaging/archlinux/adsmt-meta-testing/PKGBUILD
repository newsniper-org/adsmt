# -------------------------------------------------------------- adsmt-ffi-testing

package_adsmt-ffi-testing() {
    pkgdesc='adsmt C ABI (testing channel) — libadsmt_ffi.{so,a} + include/adsmt.h'
    depends=('gcc-libs')
    conflicts=(
        'adsmt-ffi'
        'adsmt-ffi-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm755 target/release/libadsmt_ffi.so "${pkgdir}/usr/lib/libadsmt_ffi.so"
    install -Dm644 target/release/libadsmt_ffi.a  "${pkgdir}/usr/lib/libadsmt_ffi.a"
    install -Dm644 adsmt-ffi/include/adsmt.h "${pkgdir}/usr/include/adsmt.h"
    install -Dm644 adsmt-ffi/ABI_POLICY.md "${pkgdir}/usr/share/doc/${pkgname}/ABI_POLICY.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# -------------------------------------------------------------- adsmt-src-testing

package_adsmt-src-testing() {
    pkgdesc='adsmt workspace source tree (testing channel; cargo feature flags chosen by the rebuilder)'
    depends=()
    conflicts=(
        'adsmt-src'
        'adsmt-src-git'
    )

    cd "${srcdir}/${_repo}"
    local destdir="${pkgdir}/usr/src/adsmt"
    install -dm755 "${destdir}"

    local exclude_args=(
        --exclude=target
        --exclude=node_modules
        --exclude=.git
    )
    tar -cf - "${exclude_args[@]}" --exclude="${destdir}" . | tar -xf - -C "${destdir}"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# -------------------------------------------------------------- adsmt-meta-testing

package_adsmt-meta-testing() {
    pkgdesc='Meta-package: full adsmt testing-channel install (logicutils + adsmt-cli + adsmt-lsp + adsmt-ffi, all testing)'
    depends=('logicutils-testing' 'adsmt-cli-testing' 'adsmt-lsp-testing' 'adsmt-ffi-testing')
    conflicts=(
        'adsmt-meta' 'adsmt-hpc-meta' 'adsmt-multi-meta'
        'adsmt-hpc-meta-testing' 'adsmt-multi-meta-testing'
        'adsmt-meta-git' 'adsmt-hpc-meta-git' 'adsmt-multi-meta-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}
