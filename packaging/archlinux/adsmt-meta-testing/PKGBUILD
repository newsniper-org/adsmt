# Maintainer: BYUNG-IK YEUN <yeun0908@gmail.com>
#
# adsmt testing channel — default features variant.
# Tracks adsmt main's `testing` branch (stabilisation candidates
# promoted from `main`).
#
# pkgver is git-rev-count based: 1.0.0.rc.r<count>.<short-sha>
# against the testing branch.
#
# Produces six split packages:
#   - logicutils-testing, adsmt-cli-testing, adsmt-lsp-testing,
#     adsmt-ffi-testing, adsmt-src-testing, adsmt-meta-testing
#
# See packaging/archlinux/README.md for the full channel x variant matrix.

pkgbase=adsmt-meta-testing
pkgname=('logicutils-testing' 'adsmt-cli-testing' 'adsmt-lsp-testing' 'adsmt-ffi-testing' 'adsmt-src-testing' 'adsmt-meta-testing')
pkgver=1.0.0.rc.r0.0000000
pkgrel=1
arch=('x86_64' 'aarch64')
url="https://github.com/newsniper-org/adsmt"
license=('BSD-2-Clause OR Apache-2.0 OR LGPL-2.1-or-later')
makedepends=('rust' 'cargo' 'git')
options=('!lto')
source=("git+${url}.git#branch=testing")
sha256sums=('SKIP')

_repo='adsmt'

pkgver() {
    cd "${srcdir}/${_repo}"
    printf "1.0.0.rc.r%s.%s" \
        "$(git rev-list --count HEAD)" \
        "$(git rev-parse --short=8 HEAD)"
}

prepare() {
    cd "${srcdir}/${_repo}"
    git submodule init
    git submodule update
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "${srcdir}/${_repo}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    # rc.30: adsmt-cli/oxiz links the in-process OxiZ solver so lu-smt
    # verifies `verus -V adsmt` obligations without a separate OxiZ binary.
    cargo build --release --frozen --workspace --features adsmt-cli/oxiz
}

check() {
    cd "${srcdir}/${_repo}"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --release --frozen --workspace --features adsmt-cli/oxiz
}

# ------------------------------------------------------------- logicutils-testing

package_logicutils-testing() {
    pkgdesc='Composable Unix-style utilities for logic-enhanced builds (testing channel, default features)'
    depends=('gcc-libs')
    optdepends=(
        'slurm-llnl: SLURM cluster backend (build logicutils-hpc-testing instead)'
        'gridengine: SGE cluster backend (build logicutils-hpc-testing instead)'
        'openpbs:    PBS cluster backend (build logicutils-hpc-testing instead)'
    )
    provides=(
        'freshcheck' 'stamp'
        'lu-match' 'lu-expand'
        'lu-query'  'lu-rule'
        'lu-queue'  'lu-par' 'lu-deps'
        'lu-multi'
    )
    conflicts=(
        'logicutils' 'logicutils-hpc' 'logicutils-multi'
        'logicutils-hpc-testing' 'logicutils-multi-testing'
        'logicutils-git' 'logicutils-hpc-git' 'logicutils-multi-git'
    )

    cd "${srcdir}/${_repo}"
    local bins=(
        freshcheck stamp
        lu-match lu-expand
        lu-query lu-rule
        lu-queue lu-par lu-deps
        lu-multi
    )
    for bin in "${bins[@]}"; do
        install -Dm755 "target/release/${bin}" "${pkgdir}/usr/bin/${bin}"
    done

    local man_dir="${pkgdir}/usr/share/man"
    local mansrc="state/logicutils-frozen/docs/man"
    for m1 in freshcheck stamp lu-match lu-expand lu-query lu-rule lu-queue lu-par lu-deps lu-multi; do
        install -Dm644 "${mansrc}/${m1}.1" "${man_dir}/man1/${m1}.1"
    done
    install -Dm644 "${mansrc}/lu-kb.5" "${man_dir}/man5/lu-kb.5"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# -------------------------------------------------------------- adsmt-cli-testing

package_adsmt-cli-testing() {
    pkgdesc='lu-smt — adsmt SMT solver CLI (testing channel, default features)'
    depends=('gcc-libs')
    provides=('lu-smt')
    conflicts=(
        'adsmt-cli' 'adsmt-cli-hpc' 'adsmt-cli-multi'
        'adsmt-cli-hpc-testing' 'adsmt-cli-multi-testing'
        'adsmt-cli-git' 'adsmt-cli-hpc-git' 'adsmt-cli-multi-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm755 target/release/lu-smt "${pkgdir}/usr/bin/lu-smt"
    install -Dm644 docs/man/lu-smt.1 "${pkgdir}/usr/share/man/man1/lu-smt.1"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

