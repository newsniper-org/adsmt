# Maintainer: BYUNG-IK YEUN <yeun0908@gmail.com>
#
# adsmt unstable channel — HPC features variant.
# Tracks adsmt main's `main` branch with SLURM/SGE/PBS + SHA3 features.
#
# Produces three split packages (lsp + ffi + src come from adsmt-meta-git):
#   - logicutils-hpc-git, adsmt-cli-hpc-git, adsmt-hpc-meta-git

pkgbase=adsmt-hpc-meta-git
pkgname=('logicutils-hpc-git' 'adsmt-cli-hpc-git' 'adsmt-hpc-meta-git')
pkgver=1.0.0.dev.r0.0000000
pkgrel=1
arch=('x86_64' 'aarch64')
url="https://github.com/newsniper-org/adsmt"
license=('BSD-2-Clause OR Apache-2.0 OR LGPL-2.1-or-later')
makedepends=('rust' 'cargo' 'git')
options=('!lto')
source=("git+${url}.git#branch=main")
sha256sums=('SKIP')

_repo='adsmt'
# adsmt-cli/oxiz: in-process OxiZ delegation for the verus backend (rc.30).
_features='lu-common/sha3,lu-queue/slurm,lu-queue/sge,lu-queue/pbs,adsmt-cli/oxiz'

pkgver() {
    cd "${srcdir}/${_repo}"
    printf "1.0.0.dev.r%s.%s" \
        "$(git rev-list --count HEAD)" \
        "$(git rev-parse --short=8 HEAD)"
}

prepare() {
    cd "${srcdir}/${_repo}"
    git submodule init
    git submodule update
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "${srcdir}/${_repo}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --frozen --features "${_features}" \
        -p freshcheck -p stamp \
        -p lu-match -p lu-expand \
        -p lu-query -p lu-rule \
        -p lu-queue -p lu-par -p lu-deps \
        -p lu-multi \
        -p adsmt-cli
}

check() {
    cd "${srcdir}/${_repo}"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --release --frozen --features "${_features}" \
        -p freshcheck -p stamp \
        -p lu-match -p lu-expand \
        -p lu-query -p lu-rule \
        -p lu-queue -p lu-par -p lu-deps \
        -p lu-multi \
        -p adsmt-cli
}

# -------------------------------------------------------- logicutils-hpc-git

package_logicutils-hpc-git() {
    pkgdesc='Composable Unix-style utilities for logic-enhanced builds (unstable / main-branch git build, HPC variant: SLURM/SGE/PBS + SHA3)'
    depends=('gcc-libs')
    optdepends=(
        'slurm-llnl: SLURM workload manager client'
        'gridengine: SGE workload manager client'
        'openpbs:    PBS workload manager client'
    )
    provides=(
        'freshcheck' 'stamp'
        'lu-match' 'lu-expand'
        'lu-query'  'lu-rule'
        'lu-queue'  'lu-par' 'lu-deps'
        'lu-multi'
    )
    conflicts=(
        'logicutils' 'logicutils-hpc' 'logicutils-multi'
        'logicutils-testing' 'logicutils-hpc-testing' 'logicutils-multi-testing'
        'logicutils-git' 'logicutils-multi-git'
    )

    cd "${srcdir}/${_repo}"
    local bins=(
        freshcheck stamp
        lu-match lu-expand
        lu-query lu-rule
        lu-queue lu-par lu-deps
        lu-multi
    )
    for bin in "${bins[@]}"; do
        install -Dm755 "target/release/${bin}" "${pkgdir}/usr/bin/${bin}"
    done

    local man_dir="${pkgdir}/usr/share/man"
    local mansrc="state/logicutils-frozen/docs/man"
    for m1 in freshcheck stamp lu-match lu-expand lu-query lu-rule lu-queue lu-par lu-deps lu-multi; do
        install -Dm644 "${mansrc}/${m1}.1" "${man_dir}/man1/${m1}.1"
    done
    install -Dm644 "${mansrc}/lu-kb.5" "${man_dir}/man5/lu-kb.5"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# --------------------------------------------------------- adsmt-cli-hpc-git

package_adsmt-cli-hpc-git() {
    pkgdesc='lu-smt — adsmt SMT solver CLI (unstable / main-branch git build, HPC variant: SLURM/SGE/PBS + SHA3)'
    depends=('gcc-libs')
    optdepends=(
        'slurm-llnl: SLURM workload manager client'
        'gridengine: SGE workload manager client'
        'openpbs:    PBS workload manager client'
    )
    provides=('lu-smt')
    conflicts=(
        'adsmt-cli' 'adsmt-cli-hpc' 'adsmt-cli-multi'
        'adsmt-cli-testing' 'adsmt-cli-hpc-testing' 'adsmt-cli-multi-testing'
        'adsmt-cli-git' 'adsmt-cli-multi-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm755 target/release/lu-smt "${pkgdir}/usr/bin/lu-smt"
    install -Dm644 docs/man/lu-smt.1 "${pkgdir}/usr/share/man/man1/lu-smt.1"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# --------------------------------------------------------- adsmt-hpc-meta-git

package_adsmt-hpc-meta-git() {
    pkgdesc='Meta-package: full adsmt unstable-channel HPC install (logicutils-hpc + adsmt-cli-hpc + adsmt-lsp + adsmt-ffi, all git)'
    depends=('logicutils-hpc-git' 'adsmt-cli-hpc-git' 'adsmt-lsp-git' 'adsmt-ffi-git')
    conflicts=(
        'adsmt-meta' 'adsmt-hpc-meta' 'adsmt-multi-meta'
        'adsmt-meta-testing' 'adsmt-hpc-meta-testing' 'adsmt-multi-meta-testing'
        'adsmt-meta-git' 'adsmt-multi-meta-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}
