# Maintainer: BYUNG-IK YEUN <yeun0908@gmail.com>
#
# adsmt unstable channel — slim multicall variant.
# Tracks adsmt main's `main` branch with --no-default-features
# builds (lu-multi multicall + slim lu-smt).
#
# Produces three split packages (lsp + ffi + src come from adsmt-meta-git):
#   - logicutils-multi-git, adsmt-cli-multi-git, adsmt-multi-meta-git

pkgbase=adsmt-multi-meta-git
pkgname=('logicutils-multi-git' 'adsmt-cli-multi-git' 'adsmt-multi-meta-git')
pkgver=1.0.0.dev.r0.0000000
pkgrel=1
arch=('x86_64' 'aarch64')
url="https://github.com/newsniper-org/adsmt"
license=('BSD-2-Clause OR Apache-2.0 OR LGPL-2.1-or-later')
makedepends=('rust' 'cargo' 'git')
options=('!lto')
source=("git+${url}.git#branch=main")
sha256sums=('SKIP')

_repo='adsmt'

pkgver() {
    cd "${srcdir}/${_repo}"
    printf "1.0.0.dev.r%s.%s" \
        "$(git rev-list --count HEAD)" \
        "$(git rev-parse --short=8 HEAD)"
}

prepare() {
    cd "${srcdir}/${_repo}"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "${srcdir}/${_repo}"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --frozen --no-default-features -p lu-multi
    cargo build --release --frozen --no-default-features -p adsmt-cli
}

check() {
    cd "${srcdir}/${_repo}"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --release --frozen --no-default-features -p lu-multi -p adsmt-cli
}

# -------------------------------------------------------- logicutils-multi-git

package_logicutils-multi-git() {
    pkgdesc='logicutils as a single multicall binary with symlinks (unstable / main-branch git build, Tier 1: no crypto/cluster features)'
    depends=('gcc-libs')
    provides=(
        'freshcheck' 'stamp'
        'lu-match' 'lu-expand'
        'lu-query'  'lu-rule'
        'lu-queue'  'lu-par' 'lu-deps'
        'lu-multi'
    )
    conflicts=(
        'logicutils' 'logicutils-hpc' 'logicutils-multi'
        'logicutils-testing' 'logicutils-hpc-testing' 'logicutils-multi-testing'
        'logicutils-git' 'logicutils-hpc-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm755 target/release/lu-multi "${pkgdir}/usr/bin/lu-multi"

    local utils=(
        freshcheck stamp
        lu-match lu-expand
        lu-query lu-rule
        lu-queue lu-par lu-deps
    )
    for u in "${utils[@]}"; do
        ln -s lu-multi "${pkgdir}/usr/bin/${u}"
    done

    local man_dir="${pkgdir}/usr/share/man"
    local mansrc="state/logicutils-frozen/docs/man"
    for m1 in freshcheck stamp lu-match lu-expand lu-query lu-rule lu-queue lu-par lu-deps lu-multi; do
        install -Dm644 "${mansrc}/${m1}.1" "${man_dir}/man1/${m1}.1"
    done
    install -Dm644 "${mansrc}/lu-kb.5" "${man_dir}/man5/lu-kb.5"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# --------------------------------------------------------- adsmt-cli-multi-git

package_adsmt-cli-multi-git() {
    pkgdesc='lu-smt — slim build of adsmt SMT solver CLI (unstable / main-branch git build, multi variant: --no-default-features)'
    depends=('gcc-libs')
    provides=('lu-smt')
    conflicts=(
        'adsmt-cli' 'adsmt-cli-hpc' 'adsmt-cli-multi'
        'adsmt-cli-testing' 'adsmt-cli-hpc-testing' 'adsmt-cli-multi-testing'
        'adsmt-cli-git' 'adsmt-cli-hpc-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm755 target/release/lu-smt "${pkgdir}/usr/bin/lu-smt"
    install -Dm644 docs/man/lu-smt.1 "${pkgdir}/usr/share/man/man1/lu-smt.1"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# --------------------------------------------------------- adsmt-multi-meta-git

package_adsmt-multi-meta-git() {
    pkgdesc='Meta-package: full adsmt unstable-channel slim install (logicutils-multi + adsmt-cli-multi + adsmt-lsp + adsmt-ffi, all git)'
    depends=('logicutils-multi-git' 'adsmt-cli-multi-git' 'adsmt-lsp-git' 'adsmt-ffi-git')
    conflicts=(
        'adsmt-meta' 'adsmt-hpc-meta' 'adsmt-multi-meta'
        'adsmt-meta-testing' 'adsmt-hpc-meta-testing' 'adsmt-multi-meta-testing'
        'adsmt-meta-git' 'adsmt-hpc-meta-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}
