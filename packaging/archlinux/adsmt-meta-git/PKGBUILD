# ------------------------------------------------------------------ adsmt-ffi-git

package_adsmt-ffi-git() {
    pkgdesc='adsmt C ABI (unstable / main-branch git build) — libadsmt_ffi.{so,a} + include/adsmt.h'
    depends=('gcc-libs')
    conflicts=(
        'adsmt-ffi'
        'adsmt-ffi-testing'
    )

    cd "${srcdir}/${_repo}"
    install -Dm755 target/release/libadsmt_ffi.so "${pkgdir}/usr/lib/libadsmt_ffi.so"
    install -Dm644 target/release/libadsmt_ffi.a  "${pkgdir}/usr/lib/libadsmt_ffi.a"
    install -Dm644 adsmt-ffi/include/adsmt.h "${pkgdir}/usr/include/adsmt.h"
    install -Dm644 adsmt-ffi/ABI_POLICY.md "${pkgdir}/usr/share/doc/${pkgname}/ABI_POLICY.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# ------------------------------------------------------------------ adsmt-src-git

package_adsmt-src-git() {
    pkgdesc='adsmt workspace source tree (unstable / main-branch; cargo feature flags chosen by the rebuilder)'
    depends=()
    conflicts=(
        'adsmt-src'
        'adsmt-src-testing'
    )

    cd "${srcdir}/${_repo}"
    local destdir="${pkgdir}/usr/src/adsmt"
    install -dm755 "${destdir}"

    local exclude_args=(
        --exclude=target
        --exclude=node_modules
        --exclude=.git
    )
    tar -cf - "${exclude_args[@]}" --exclude="${destdir}" . | tar -xf - -C "${destdir}"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}

# ----------------------------------------------------------------- adsmt-meta-git

package_adsmt-meta-git() {
    pkgdesc='Meta-package: full adsmt unstable-channel install (logicutils + adsmt-cli + adsmt-lsp + adsmt-ffi, all git)'
    depends=('logicutils-git' 'adsmt-cli-git' 'adsmt-lsp-git' 'adsmt-ffi-git')
    conflicts=(
        'adsmt-meta' 'adsmt-hpc-meta' 'adsmt-multi-meta'
        'adsmt-meta-testing' 'adsmt-hpc-meta-testing' 'adsmt-multi-meta-testing'
        'adsmt-hpc-meta-git' 'adsmt-multi-meta-git'
    )

    cd "${srcdir}/${_repo}"
    install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    install -Dm644 LICENSE-BSD.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-BSD.txt"
    install -Dm644 LICENSE-APACHE.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE.txt"
    install -Dm644 LICENSE-LGPL.txt "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-LGPL.txt"
}
